def merge_the_tools(string, k):
    subs = [string[i:i+k] if i+k <= len(string) else string[i:] for i in range(0, len(string), k)]
    uniques = []
    for sub in subs:
        u = ""
        for char in sub:
            if char not in u:
                u = u + char
        uniques.append(u)
    print("\n".join(uniques))

if __name__ == '__main__':
    string, k = input(), int(input())
    merge_the_tools(string, k)
